---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Quiz from '../components/Quiz.astro';
import { Image } from 'astro:assets';
import { CATEGORIES } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & {
	headings: Array<{
		depth: number;
		slug: string;
		text: string;
	}>;
	slug: string;
};

const { 
	title, 
	description, 
	pubDate, 
	updatedDate, 
	heroImage, 
	author,
	category,
	tags,
	hasQuiz,
	quizTitle,
	quizDescription,
	quizDifficulty,
	quizTimeLimit,
	readingTime,
	featured,
	tableOfContents,
	headings,
	slug
} = Astro.props;

const categoryInfo = CATEGORIES[category as keyof typeof CATEGORIES];

// Load quiz data if hasQuiz is true
let quizData = null;
if (hasQuiz) {
	try {
		quizData = await import(`../content/blog/${slug}/quiz.json`);
	} catch (error) {
		console.warn(`Could not load quiz for ${slug}:`, error);
	}
}
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style define:vars={{ categoryColor: categoryInfo?.color || '#6b7280' }}>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.article-meta {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 1rem;
				flex-wrap: wrap;
				margin: 1rem 0;
			}
			.meta-item {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.875rem;
				color: rgb(var(--gray));
			}
			.category-badge {
				padding: 0.25rem 0.75rem;
				border-radius: 1rem;
				font-size: 0.875rem;
				font-weight: 500;
				background: var(--categoryColor);
				color: white;
			}
			.tags {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				justify-content: center;
				margin: 1rem 0;
			}
			.tag {
				padding: 0.25rem 0.5rem;
				background: rgb(var(--gray-light));
				border: 1px solid rgb(var(--gray));
				border-radius: 0.375rem;
				font-size: 0.75rem;
				color: rgb(var(--gray-dark));
			}
			.article-layout {
				display: grid;
				grid-template-columns: 1fr 300px;
				gap: 2rem;
				max-width: 1200px;
				margin: 0 auto;
				padding: 1rem;
			}
			.article-content {
				min-width: 0;
			}
			.article-sidebar {
				position: sticky;
				top: 2rem;
				height: fit-content;
			}
			@media (max-width: 1024px) {
				.article-layout {
					grid-template-columns: 1fr;
				}
				.article-sidebar {
					position: static;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				
				<div class="article-layout">
					<div class="article-content">
						<div class="prose">
							<div class="title">
								<div class="date">
									<FormattedDate date={pubDate} />
									{
										updatedDate && (
											<div class="last-updated-on">
												Cập nhật lần cuối: <FormattedDate date={updatedDate} />
											</div>
										)
									}
								</div>
								<h1>{title}</h1>
								
								<div class="article-meta">
									<div class="meta-item">
										<span>👤</span>
										<span>{author}</span>
									</div>
									<div class="meta-item">
										<span>📚</span>
										<span class="category-badge">{categoryInfo?.name || category}</span>
									</div>
									{readingTime && (
										<div class="meta-item">
											<span>⏱️</span>
											<span>{readingTime} phút đọc</span>
										</div>
									)}
									{featured && (
										<div class="meta-item">
											<span>⭐</span>
											<span>Featured</span>
										</div>
									)}
								</div>
								
								{tags && tags.length > 0 && (
									<div class="tags">
										{tags.map(tag => (
											<span class="tag">#{tag}</span>
										))}
									</div>
								)}
								
								<hr />
							</div>
							
							<slot />
							
							{hasQuiz && quizData && (
								<div class="quiz-section">
									<hr />
									<h2>Quiz: Kiểm tra kiến thức</h2>
									<p>Hãy làm quiz để kiểm tra mức độ hiểu bài của bạn!</p>
									<Quiz 
										quizData={quizData.default || quizData}
										title={quizTitle}
										description={quizDescription}
										difficulty={quizDifficulty}
										timeLimit={quizTimeLimit}
									/>
								</div>
							)}
						</div>
					</div>
					
					{tableOfContents && (
						<div class="article-sidebar">
							<TableOfContents headings={headings} />
						</div>
					)}
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
