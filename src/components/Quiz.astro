---
export interface Props {
  quizData: {
    questions: Array<{
      question: string;
      hint?: string;
      answerOptions: Array<{
        text: string;
        rationale: string;
        isCorrect: boolean;
      }>;
    }>;
  };
  title?: string;
  description?: string;
  difficulty?: string;
  timeLimit?: number;
  showAnswersImmediately?: boolean;
  className?: string;
}

const { 
  quizData, 
  title = "Quiz", 
  description = "",
  difficulty = "intermediate",
  timeLimit,
  showAnswersImmediately = false,
  className = ""
} = Astro.props;

// Shuffle questions and answer options
const shuffledQuestions = quizData.questions
  .map(q => ({
    ...q,
    answerOptions: [...q.answerOptions].sort(() => Math.random() - 0.5)
  }))
  .sort(() => Math.random() - 0.5);
---

<div class={`quiz-container ${className}`}>
  <div class="quiz-header">
    <h2 class="quiz-title">{title}</h2>
    {description && <p class="quiz-description">{description}</p>}
    <div class="quiz-meta">
      <span class="quiz-difficulty difficulty-{difficulty}">{difficulty}</span>
      <span class="quiz-count">{shuffledQuestions.length} câu hỏi</span>
      {timeLimit && <span class="quiz-timer" id="quiz-timer">{timeLimit}s</span>}
    </div>
  </div>

  <form class="quiz-form" id="quiz-form">
    {shuffledQuestions.map((question, questionIndex) => (
      <div class="question-container" data-question-index={questionIndex}>
        <div class="question-header">
          <h3 class="question-title">
            Câu {questionIndex + 1}: {question.question}
          </h3>
          {question.hint && (
            <div class="question-hint">
              <span class="hint-icon">💡</span>
              <span class="hint-text">{question.hint}</span>
            </div>
          )}
        </div>

        <div class="answer-options">
          {question.answerOptions.map((option, optionIndex) => (
            <label class="answer-option">
              <input
                type="radio"
                name={`question-${questionIndex}`}
                value={optionIndex}
                class="answer-input"
                data-correct={option.isCorrect}
              />
              <span class="answer-text">{option.text}</span>
              {showAnswersImmediately && (
                <div class="answer-rationale {option.isCorrect ? 'correct' : 'incorrect'}">
                  {option.rationale}
                </div>
              )}
            </label>
          ))}
        </div>

        <div class="question-feedback" style="display: none;">
          <div class="feedback-correct">
            <span class="feedback-icon">✅</span>
            <span class="feedback-text">Đúng!</span>
          </div>
          <div class="feedback-incorrect">
            <span class="feedback-icon">❌</span>
            <span class="feedback-text">Sai!</span>
          </div>
        </div>
      </div>
    ))}

    <div class="quiz-actions">
      <button type="submit" class="quiz-submit-btn">
        Nộp bài
      </button>
      <button type="button" class="quiz-reset-btn" id="quiz-reset">
        Làm lại
      </button>
    </div>
  </form>

  <div class="quiz-results" id="quiz-results" style="display: none;">
    <h3 class="results-title">Kết quả</h3>
    <div class="results-summary">
      <div class="score-display">
        <span class="score-text">Điểm: </span>
        <span class="score-value" id="score-value">0/0</span>
        <span class="score-percentage" id="score-percentage">(0%)</span>
      </div>
      <div class="time-display" id="time-display"></div>
    </div>
    
    <div class="results-breakdown">
      <h4>Chi tiết từng câu:</h4>
      <div class="question-results" id="question-results"></div>
    </div>
  </div>
</div>

<style>
  .quiz-container {
    max-width: 800px;
    margin: 2rem auto;
    padding: 2rem;
    background: var(--theme-bg);
    border: 1px solid var(--theme-border);
    border-radius: 0.75rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .quiz-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--theme-border);
  }

  .quiz-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 0.5rem 0;
    color: var(--theme-text);
  }

  .quiz-description {
    color: var(--theme-text-light);
    margin: 0 0 1rem 0;
    line-height: 1.6;
  }

  .quiz-meta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .quiz-difficulty {
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .difficulty-beginner {
    background: #dcfce7;
    color: #166534;
  }

  .difficulty-intermediate {
    background: #fef3c7;
    color: #92400e;
  }

  .difficulty-advanced {
    background: #fee2e2;
    color: #991b1b;
  }

  .quiz-count, .quiz-timer {
    padding: 0.25rem 0.75rem;
    background: var(--theme-bg-secondary);
    border-radius: 1rem;
    font-size: 0.875rem;
    color: var(--theme-text-light);
  }

  .question-container {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--theme-bg-secondary);
    border-radius: 0.5rem;
    border: 1px solid var(--theme-border);
  }

  .question-header {
    margin-bottom: 1rem;
  }

  .question-title {
    font-size: 1.125rem;
    font-weight: 500;
    margin: 0 0 0.5rem 0;
    color: var(--theme-text);
  }

  .question-hint {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem;
    background: #fef3c7;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    color: #92400e;
  }

  .hint-icon {
    font-size: 1rem;
  }

  .answer-options {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .answer-option {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    background: var(--theme-bg);
    border: 2px solid var(--theme-border);
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .answer-option:hover {
    border-color: var(--theme-accent);
    background: var(--theme-bg-accent);
  }

  .answer-input {
    margin: 0;
    margin-top: 0.125rem;
  }

  .answer-text {
    flex: 1;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--theme-text);
  }

  .answer-rationale {
    margin-top: 0.5rem;
    padding: 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    line-height: 1.4;
  }

  .answer-rationale.correct {
    background: #dcfce7;
    color: #166534;
    border-left: 4px solid #22c55e;
  }

  .answer-rationale.incorrect {
    background: #fee2e2;
    color: #991b1b;
    border-left: 4px solid #ef4444;
  }

  .question-feedback {
    margin-top: 1rem;
    padding: 1rem;
    border-radius: 0.5rem;
    font-weight: 500;
  }

  .feedback-correct {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #166534;
    background: #dcfce7;
    padding: 0.75rem;
    border-radius: 0.375rem;
  }

  .feedback-incorrect {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #991b1b;
    background: #fee2e2;
    padding: 0.75rem;
    border-radius: 0.375rem;
  }

  .quiz-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2rem;
  }

  .quiz-submit-btn, .quiz-reset-btn {
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 0.5rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .quiz-submit-btn {
    background: var(--theme-accent);
    color: white;
  }

  .quiz-submit-btn:hover {
    background: var(--theme-accent-hover);
  }

  .quiz-reset-btn {
    background: var(--theme-bg-secondary);
    color: var(--theme-text);
    border: 1px solid var(--theme-border);
  }

  .quiz-reset-btn:hover {
    background: var(--theme-bg-accent);
  }

  .quiz-results {
    margin-top: 2rem;
    padding: 2rem;
    background: var(--theme-bg-secondary);
    border-radius: 0.5rem;
    border: 1px solid var(--theme-border);
  }

  .results-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 1rem 0;
    color: var(--theme-text);
  }

  .results-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: var(--theme-bg);
    border-radius: 0.5rem;
  }

  .score-display {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .score-value {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--theme-accent);
  }

  .score-percentage {
    color: var(--theme-text-light);
  }

  .time-display {
    color: var(--theme-text-light);
    font-size: 0.875rem;
  }

  .results-breakdown h4 {
    margin: 0 0 1rem 0;
    color: var(--theme-text);
  }

  .question-results {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .question-result {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
  }

  .question-result.correct {
    background: #dcfce7;
    color: #166534;
  }

  .question-result.incorrect {
    background: #fee2e2;
    color: #991b1b;
  }

  @media (max-width: 768px) {
    .quiz-container {
      margin: 1rem;
      padding: 1rem;
    }

    .quiz-meta {
      flex-direction: column;
      gap: 0.5rem;
    }

    .quiz-actions {
      flex-direction: column;
    }

    .results-summary {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>

<script>
  class QuizManager {
    constructor() {
      this.form = document.getElementById('quiz-form');
      this.results = document.getElementById('quiz-results');
      this.resetBtn = document.getElementById('quiz-reset');
      this.timer = document.getElementById('quiz-timer');
      this.timeLimit = {timeLimit};
      this.timeRemaining = this.timeLimit;
      this.timerInterval = null;
      this.isSubmitted = false;
      
      this.init();
    }

    init() {
      this.form.addEventListener('submit', (e) => this.handleSubmit(e));
      this.resetBtn.addEventListener('click', () => this.resetQuiz());
      
      if (this.timeLimit) {
        this.startTimer();
      }
    }

    startTimer() {
      this.timerInterval = setInterval(() => {
        this.timeRemaining--;
        if (this.timer) {
          this.timer.textContent = `${this.timeRemaining}s`;
        }
        
        if (this.timeRemaining <= 0) {
          this.handleSubmit(new Event('submit'));
        }
      }, 1000);
    }

    stopTimer() {
      if (this.timerInterval) {
        clearInterval(this.timerInterval);
      }
    }

    handleSubmit(e) {
      e.preventDefault();
      if (this.isSubmitted) return;
      
      this.isSubmitted = true;
      this.stopTimer();
      
      const formData = new FormData(this.form);
      const answers = {};
      
      // Collect answers
      for (const [name, value] of formData.entries()) {
        const questionIndex = parseInt(name.split('-')[1]);
        answers[questionIndex] = parseInt(value);
      }
      
      // Calculate score
      const questions = document.querySelectorAll('.question-container');
      let correctAnswers = 0;
      const questionResults = [];
      
      questions.forEach((question, index) => {
        const questionIndex = parseInt(question.dataset.questionIndex);
        const selectedOption = answers[questionIndex];
        const options = question.querySelectorAll('.answer-option');
        
        let isCorrect = false;
        if (selectedOption !== undefined) {
          const selectedInput = options[selectedOption].querySelector('input');
          isCorrect = selectedInput.dataset.correct === 'true';
          if (isCorrect) correctAnswers++;
        }
        
        questionResults.push({
          questionIndex,
          isCorrect,
          selectedOption
        });
        
        // Show feedback
        this.showQuestionFeedback(question, isCorrect, selectedOption);
      });
      
      // Show results
      this.showResults(correctAnswers, questions.length, questionResults);
    }

    showQuestionFeedback(question, isCorrect, selectedOption) {
      const feedback = question.querySelector('.question-feedback');
      const correctFeedback = feedback.querySelector('.feedback-correct');
      const incorrectFeedback = feedback.querySelector('.feedback-incorrect');
      
      if (isCorrect) {
        correctFeedback.style.display = 'flex';
      } else {
        incorrectFeedback.style.display = 'flex';
      }
      
      feedback.style.display = 'block';
    }

    showResults(correctAnswers, totalQuestions, questionResults) {
      const scoreValue = document.getElementById('score-value');
      const scorePercentage = document.getElementById('score-percentage');
      const timeDisplay = document.getElementById('time-display');
      const questionResultsContainer = document.getElementById('question-results');
      
      const percentage = Math.round((correctAnswers / totalQuestions) * 100);
      
      scoreValue.textContent = `${correctAnswers}/${totalQuestions}`;
      scorePercentage.textContent = `(${percentage}%)`;
      
      if (this.timeLimit) {
        const timeUsed = this.timeLimit - this.timeRemaining;
        timeDisplay.textContent = `Thời gian: ${timeUsed}s`;
      }
      
      // Show question breakdown
      questionResultsContainer.innerHTML = '';
      questionResults.forEach((result, index) => {
        const resultElement = document.createElement('div');
        resultElement.className = `question-result ${result.isCorrect ? 'correct' : 'incorrect'}`;
        resultElement.innerHTML = `
          <span>${result.isCorrect ? '✅' : '❌'}</span>
          <span>Câu ${index + 1}</span>
        `;
        questionResultsContainer.appendChild(resultElement);
      });
      
      this.results.style.display = 'block';
      this.form.style.display = 'none';
    }

    resetQuiz() {
      this.isSubmitted = false;
      this.timeRemaining = this.timeLimit;
      
      // Reset form
      this.form.reset();
      
      // Hide feedback and results
      document.querySelectorAll('.question-feedback').forEach(feedback => {
        feedback.style.display = 'none';
      });
      
      this.results.style.display = 'none';
      this.form.style.display = 'block';
      
      // Reset timer
      if (this.timer) {
        this.timer.textContent = `${this.timeRemaining}s`;
      }
      
      if (this.timeLimit) {
        this.startTimer();
      }
    }
  }

  // Initialize quiz when DOM is loaded
  document.addEventListener('DOMContentLoaded', () => {
    new QuizManager();
  });
</script> 