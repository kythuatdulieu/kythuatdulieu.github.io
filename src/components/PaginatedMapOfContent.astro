---
import { getCollection } from 'astro:content';
import { conceptCategories } from '../config/categories.js';

const allDocs = await getCollection('docs');
const contentDocs = allDocs.filter(doc => doc.id !== 'index.mdx' && !doc.id.startsWith('quizzes/'));

const tree = {};
contentDocs.forEach(doc => {
  const parts = doc.id.split('/');
  if (parts.length === 1) return;

  const rootFolder = parts[0];
  if (!tree[rootFolder]) {
    tree[rootFolder] = { name: rootFolder, categories: {} };
  }
  
  let catSlug = 'other';
  let catLabel = 'Bài viết khác';
  
  if (rootFolder === 'concepts' && parts.length > 2) {
      catSlug = parts[1];
      const found = conceptCategories.find(c => c.slug === catSlug);
      if (found) catLabel = found.label;
      else {
          catLabel = parts[1].replace(/^\d+-/, '').replace(/-/g, ' ');
          catLabel = catLabel.charAt(0).toUpperCase() + catLabel.slice(1);
      }
  } else {
      const customLabels = {
          'e2e': 'Dự Án Data Engineering (E2E)',
          'aws': 'Dự Án AWS',
          'azure': 'Dự Án Azure',
          'gcp': 'Dự Án GCP',
          'dwh': 'Dự Án Data Warehouse',
          'on-prem': 'Dự Án On-Premise',
          'system-design': 'Thiết Kế Hệ Thống',
          'core-paths': 'Lộ Trình Cốt Lõi',
          'specializations': 'Chuyên Ngành Hẹp',
          'leadership-culture': 'Lãnh Đạo & Văn Hóa'
      };
      if (parts.length === 2) {
          catLabel = 'Tất cả bài viết';
      } else {
          catSlug = parts[1];
          catLabel = customLabels[catSlug] || (parts[1].charAt(0).toUpperCase() + parts[1].slice(1).replace(/-/g, ' '));
      }
  }

  if (!tree[rootFolder].categories[catSlug]) {
      tree[rootFolder].categories[catSlug] = { slug: catSlug, label: catLabel, docs: [] };
  }

  let title = doc.data.title;
  
  tree[rootFolder].categories[catSlug].docs.push({ title, url: `/${doc.slug}/` });
});

const sectionInfo = {
  'learning-paths': {
      label: 'Lộ Trình Học Tập',
      svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path></svg>`
  },
  'concepts': {
      label: 'Khái Niệm Cốt Lõi',
      svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`
  },
  'projects': {
      label: 'Dự Án Thực Chiến',
      svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>`
  },
  'interview': {
      label: 'Câu Hỏi Phỏng Vấn',
      svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>`
  }
};

const sortedRoots = ['concepts', 'learning-paths', 'projects', 'interview'].filter(r => tree[r]);

const domainsData = sortedRoots.map(rootKey => {
    const data = tree[rootKey];
    const info = sectionInfo[rootKey];
    const categoriesArray = Object.values(data.categories);
    
    return { 
        id: rootKey,
        label: info.label,
        svg: info.svg,
        categories: categoriesArray 
    };
});
---

<div class="minimal-explorer">
  <!-- Tab Navigation -->
  <nav class="explorer-tabs">
    {domainsData.map((domain, index) => (
      <div class={`tab-btn ${index === 0 ? 'active' : ''}`} data-target={domain.id} tabindex="0" role="button">
        <span class="tab-icon" set:html={domain.svg} />
        <span class="tab-label">{domain.label.split('. ')[1] || domain.label}</span>
      </div>
    ))}
    <div class="tab-divider"></div>
    <a href="/quizzes/" class="tab-btn quiz-btn">
      <span class="tab-icon">🔥</span>
      <span class="tab-label">Luyện thi Certificate</span>
    </a>
  </nav>

  <!-- Tab Contents -->
  <div class="explorer-content">
    {domainsData.map((domain, index) => (
      <div class={`tab-panel ${index === 0 ? 'active' : ''}`} id={`panel-${domain.id}`}>
        
        <div class="clean-table">
          {domain.categories.map((cat) => (
            <div class="table-row" id={cat.slug}>
              <!-- Left Column: Category Name -->
              <div class="table-col-cat">
                <h3 class="cat-title">{cat.label}</h3>
                <span class="cat-count">{cat.docs.length} bài viết</span>
              </div>
              
              <!-- Right Column: Links -->
              <div class="table-col-links">
                {cat.docs.map((doc) => (
                  <a href={doc.url} class="doc-link">
                    <span class="link-bullet"></span>
                    <span class="link-text">{doc.title}</span>
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
        
      </div>
    ))}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabBtns = document.querySelectorAll('.tab-btn:not(a)');
    const panels = document.querySelectorAll('.tab-panel');

    function activateTab(targetId) {
      tabBtns.forEach(b => b.classList.remove('active'));
      panels.forEach(p => p.classList.remove('active'));
      
      const btn = document.querySelector(`.tab-btn[data-target="${targetId}"]`);
      if (btn) btn.classList.add('active');
      
      const targetPanel = document.getElementById(`panel-${targetId}`);
      if (targetPanel) {
        targetPanel.classList.add('active');
      }
    }

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        activateTab(btn.getAttribute('data-target'));
      });
    });

    // Handle hash links (Anchor)
    if (window.location.hash) {
      const targetHash = window.location.hash.substring(1);
      const targetEl = document.getElementById(targetHash);
      if (targetEl) {
        const parentPanel = targetEl.closest('.tab-panel');
        if (parentPanel) {
          const panelId = parentPanel.id.replace('panel-', '');
          activateTab(panelId);
          setTimeout(() => {
            targetEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
            targetEl.classList.add('highlight-row');
            setTimeout(() => {
              targetEl.classList.remove('highlight-row');
            }, 2000);
          }, 100);
        }
      }
    }
  });
</script>

<style is:global>
  /* Hide default Starlight title */
  .sl-markdown-content > h1#_top,
  .content-panel:has(h1#_top) {
    display: none !important;
  }
</style>

<style>
/* Minimalist Container */
.minimal-explorer {
  margin-top: 1rem;
  background: var(--sl-color-bg);
  border: 1px solid var(--sl-color-hairline, rgba(128,128,128,0.2));
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

/* Tabs */
.explorer-tabs {
  display: flex;
  align-items: center;
  overflow-x: auto;
  border-bottom: 1px solid var(--sl-color-hairline, rgba(128,128,128,0.2));
  background: var(--sl-color-bg-nav);
  padding: 0.5rem;
  gap: 0.5rem;
  scrollbar-width: none;
  min-height: 58px;
}
.explorer-tabs::-webkit-scrollbar { display: none; }

.tab-btn {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  height: 42px !important;
  min-height: 42px !important;
  max-height: 42px !important;
  box-sizing: border-box !important;
  gap: 0.5rem !important;
  padding: 0 1rem !important;
  margin: 0 !important;
  background: transparent;
  border: 1px solid transparent !important;
  border-radius: 6px;
  color: var(--sl-color-gray-2);
  font-size: 0.95rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
  white-space: nowrap;
  text-decoration: none !important;
}

.tab-btn * {
  display: inline-flex !important;
  align-items: center !important;
  line-height: 1 !important;
  margin: 0 !important;
  padding: 0 !important;
}

.tab-btn:hover {
  background: rgba(128, 128, 128, 0.1);
  color: var(--sl-color-text);
}

.tab-btn.active {
  background: var(--sl-color-text-accent);
  color: var(--sl-color-bg);
}

.tab-icon {
  display: flex;
  opacity: 0.8;
  font-size: 1.1rem; /* For emoji sizing */
}
.tab-btn.active .tab-icon {
  opacity: 1;
}

.tab-label {
  transform: translateY(1px); /* Micro-adjustment if needed, but flex should handle it */
}

.tab-divider {
  width: 1px;
  background: var(--sl-color-hairline);
  margin: 0.5rem 0.25rem;
}

.quiz-btn {
  color: #ea580c;
  text-decoration: none !important;
}
.quiz-btn:hover {
  background: rgba(234, 88, 12, 0.1);
}

/* Content */
.explorer-content {
  padding: 0;
}

.tab-panel {
  display: none;
}
.tab-panel.active {
  display: block;
}

/* Clean Table */
.clean-table {
  display: flex;
  flex-direction: column;
}

.table-row {
  display: flex;
  flex-direction: column;
  border-bottom: 1px solid var(--sl-color-hairline, rgba(128,128,128,0.15));
  transition: background-color 0.3s ease;
}
.table-row:last-child {
  border-bottom: none;
}

@media (min-width: 768px) {
  .table-row {
    flex-direction: row;
  }
}

.highlight-row {
  background-color: rgba(var(--sl-color-text-accent-rgb, 100, 150, 255), 0.1);
}

/* Left Column: Category */
.table-col-cat {
  padding: 1.5rem;
  background: rgba(128, 128, 128, 0.03);
}

@media (min-width: 768px) {
  .table-col-cat {
    width: 280px;
    flex-shrink: 0;
    border-right: 1px solid var(--sl-color-hairline, rgba(128,128,128,0.15));
  }
}

.cat-title {
  margin: 0 !important;
  font-size: 1.1rem !important;
  font-weight: 600;
  color: var(--sl-color-text);
  line-height: 1.4;
}

.cat-count {
  display: inline-block;
  margin-top: 0.5rem;
  font-size: 0.8rem;
  color: var(--sl-color-gray-3);
}

/* Right Column: Links */
.table-col-links {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

@media (min-width: 768px) {
  .table-col-links {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem 2rem;
  }
}

.doc-link {
  display: flex;
  align-items: flex-start;
  gap: 0.5rem;
  color: var(--sl-color-text-accent);
  text-decoration: none !important;
  font-size: 0.95rem;
  line-height: 1.4;
  transition: all 0.2s ease;
}

.link-bullet {
  margin-top: 0.4rem;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: var(--sl-color-text-accent);
  opacity: 0.4;
  flex-shrink: 0;
  transition: opacity 0.2s ease;
}

.doc-link:hover {
  color: var(--sl-color-text);
}
.doc-link:hover .link-bullet {
  opacity: 1;
}

.link-text {
  flex: 1;
}
</style>
