---
import { getCollection } from 'astro:content';
import { conceptCategories } from '../config/categories.js';

const allDocs = await getCollection('docs');
const contentDocs = allDocs.filter(doc => doc.id !== 'index.mdx' && !doc.id.startsWith('quizzes/'));

const tree = {};
contentDocs.forEach(doc => {
  const parts = doc.id.split('/');
  if (parts.length === 1) return;

  const rootFolder = parts[0];
  if (!tree[rootFolder]) {
    tree[rootFolder] = { name: rootFolder, categories: {} };
  }
  
  let catSlug = 'other';
  let catLabel = 'Bài viết khác';
  
  if (rootFolder === 'concepts' && parts.length > 2) {
      catSlug = parts[1];
      const found = conceptCategories.find(c => c.slug === catSlug);
      if (found) catLabel = found.label;
      else {
          catLabel = parts[1].replace(/^\d+-/, '').replace(/-/g, ' ');
          catLabel = catLabel.charAt(0).toUpperCase() + catLabel.slice(1);
      }
  } else {
      const customLabels = {
          'e2e': 'Dự Án Data Engineering (E2E)',
          'aws': 'Dự Án AWS',
          'azure': 'Dự Án Azure',
          'gcp': 'Dự Án GCP',
          'dwh': 'Dự Án Data Warehouse',
          'on-prem': 'Dự Án On-Premise',
          'system-design': 'Thiết Kế Hệ Thống',
          'core-paths': 'Lộ Trình Cốt Lõi',
          'specializations': 'Chuyên Ngành Hẹp',
          'leadership-culture': 'Lãnh Đạo & Văn Hóa'
      };
      if (parts.length === 2) {
          catLabel = 'Tất cả bài viết';
      } else {
          catSlug = parts[1];
          catLabel = customLabels[catSlug] || (parts[1].charAt(0).toUpperCase() + parts[1].slice(1).replace(/-/g, ' '));
      }
  }

  if (!tree[rootFolder].categories[catSlug]) {
      tree[rootFolder].categories[catSlug] = { label: catLabel, docs: [] };
  }

  let title = doc.data.title;
  const match = title.match(/-\s*([a-zA-Z0-9\s]+)$/);
  if (match && match[1]) title = match[1].trim();

  tree[rootFolder].categories[catSlug].docs.push({ title, url: `/${doc.slug}/` });
});

const sectionInfo = {
  'learning-paths': {
      label: 'Lộ Trình Học Tập',
      svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path></svg>`
  },
  'concepts': {
      label: 'Khái Niệm Cốt Lõi',
      svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`
  },
  'projects': {
      label: 'Dự Án Thực Chiến',
      svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>`
  },
  'interview': {
      label: 'Câu Hỏi Phỏng Vấn',
      svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>`
  }
};

const sortedRoots = ['concepts', 'learning-paths', 'projects', 'interview'].filter(r => tree[r]);

const domainsData = sortedRoots.map(rootKey => {
    const data = tree[rootKey];
    const info = sectionInfo[rootKey];
    const categoriesArray = Object.values(data.categories);
    
    return { 
        id: rootKey,
        label: info.label,
        svg: info.svg,
        categories: categoriesArray 
    };
});
---

<div class="interactive-explorer">
  <div class="sidebar-tabs">
    {domainsData.map((domain, index) => (
      <button class={`tab-btn ${index === 0 ? 'active' : ''}`} data-target={domain.id}>
        <span class="tab-icon" set:html={domain.svg} />
        <span class="tab-label">{domain.label.split('. ')[1] || domain.label}</span>
      </button>
    ))}
  </div>

  <div class="content-panels">
    {domainsData.map((domain, index) => {
      return (
        <div class={`tab-content ${index === 0 ? 'active' : ''}`} id={`panel-${domain.id}`}>
          <div class="docs-grid-container">
            <div class="moc-table">
              {domain.categories.map((cat) => (
                <div class="moc-row">
                  <div class="moc-col-cat">
                    <span class="cat-label-text">{cat.label}</span>
                  </div>
                  <div class="moc-col-links">
                    {cat.docs.map((doc) => (
                      <a href={doc.url} class="concept-link-item">{doc.title}</a>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    // Tab Switching Only (No Pagination, No Timer)
    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        tabBtns.forEach(b => b.classList.remove('active'));
        tabContents.forEach(c => c.classList.remove('active'));
        
        btn.classList.add('active');
        const targetId = btn.getAttribute('data-target');
        document.getElementById(`panel-${targetId}`).classList.add('active');
      });
    });
  });
</script>

<style is:global>
  /* Removed page-level overflow constraints so scrolling is native */
</style>
<style>
.interactive-explorer {
  display: flex;
  flex-direction: column;
  background: var(--sl-color-bg-nav, rgba(20, 20, 25, 0.4));
  border: 1px solid var(--sl-color-hairline, rgba(255, 255, 255, 0.08));
  border-radius: 12px;
}

@media (min-width: 768px) {
  .interactive-explorer {
    flex-direction: row;
  }
}

.sidebar-tabs {
  display: flex;
  flex-direction: row;
  overflow-x: auto;
  border-bottom: 1px solid var(--sl-color-hairline);
  padding: 0.5rem;
  gap: 0.5rem;
  scrollbar-width: thin;
}

@media (min-width: 768px) {
  .sidebar-tabs {
    flex-direction: column;
    min-width: 240px;
    max-width: 280px;
    border-bottom: none;
    border-right: 1px solid var(--sl-color-hairline);
    padding: 1rem;
    overflow-y: auto;
  }
}

.tab-btn {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  width: 100%;
  padding: 0.75rem 1rem;
  background: transparent;
  border: 1px solid transparent;
  border-radius: 8px;
  color: var(--sl-color-gray-2);
  font-size: 0.95rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
  white-space: nowrap;
}

.tab-btn:hover {
  background: rgba(255, 255, 255, 0.03);
  color: var(--sl-color-white);
}

.tab-btn.active {
  background: rgba(var(--sl-color-accent-rgb, 100, 100, 255), 0.1);
  border-color: rgba(var(--sl-color-accent-rgb, 100, 100, 255), 0.2);
  color: var(--sl-color-white);
}

.tab-icon {
  display: flex;
  color: var(--sl-color-accent);
}

.content-panels {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.tab-content {
  display: none;
  flex-direction: column;
}

.tab-content.active {
  display: flex;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(5px); }
  to { opacity: 1; transform: translateY(0); }
}

.docs-grid-container {
  padding: 1.5rem;
}

/* Table Style Layout */
.moc-table {
  display: flex;
  flex-direction: column;
  border-radius: 8px;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.moc-row {
  display: flex;
  flex-direction: column;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.moc-row:last-child {
  border-bottom: none;
}

@media (min-width: 640px) {
  .moc-row {
    flex-direction: row;
  }
}

.moc-col-cat {
  padding: 1.25rem 1rem;
  background: rgba(255, 255, 255, 0.02);
  font-weight: 600;
  color: var(--sl-color-white);
  font-size: 0.95rem;
  line-height: 1.4;
}

@media (min-width: 640px) {
  .moc-col-cat {
    width: 30%;
    min-width: 200px;
    border-right: 1px solid rgba(255, 255, 255, 0.05);
  }
}

/* CSS Grid for Article Links */
.moc-col-links {
  padding: 1.25rem 1rem;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 0.75rem 1rem;
  flex: 1;
}

.concept-link-item {
  display: flex;
  align-items: flex-start;
  font-size: 0.95rem;
  color: var(--sl-color-accent);
  text-decoration: none !important;
  transition: color 0.2s ease;
  line-height: 1.4;
}

.concept-link-item::before {
  content: '→';
  color: var(--sl-color-gray-4);
  margin-right: 0.4rem;
  font-size: 0.9rem;
  margin-top: 0.1rem;
}

.concept-link-item:hover {
  color: var(--sl-color-accent-high);
  text-decoration: underline !important;
}
</style>
