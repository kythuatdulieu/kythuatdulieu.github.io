---
import { getCollection } from 'astro:content';

const allDocs = await getCollection('docs');
const existingConcepts = allDocs.filter(doc => doc.id.startsWith('concepts/'));

// Create a lookup map for existing concepts by slug or title
const conceptMap = new Map();
existingConcepts.forEach(doc => {
    const rawSlug = doc.id.replace('concepts/', '').replace('.md', '').replace('.mdx', '');
    const title = doc.data.title.toLowerCase();
    conceptMap.set(rawSlug, `/${doc.slug}/`);
    conceptMap.set(title, `/${doc.slug}/`);
    
    // Also map by extracting trailing title parts (e.g. "Concept - Parquet")
    const match = title.match(/-\s*([a-z0-9\s]+)$/);
    if (match && match[1]) {
        conceptMap.set(match[1].trim(), `/${doc.slug}/`);
    }
});

// Helper to find URL
function getConceptUrl(name) {
    const searchName = name.toLowerCase();
    const slugName = searchName.replace(/[^a-z0-9]+/g, '-');
    return conceptMap.get(searchName) || conceptMap.get(slugName) || null;
}

const hardcodedMOC = [
  {
    category: "Storage & Warehousing",
    concepts: ["OLTP", "OLAP", "ACID Transactions", "Data Warehouse", "Data Lake", "Data Lakehouse", "Cloud Data Warehouses", "Compute and Storage Separation", "Storage Layer", "Three Vs"]
  },
  {
    category: "Open Table & File Formats",
    concepts: ["Data Lake File Formats", "Data Lake Table Format", "Apache Parquet", "Apache Arrow", "Apache Avro", "Apache Iceberg", "Delta Lake", "Time Travel"]
  },
  {
    category: "Data Architectures & Stacks",
    concepts: ["Data Engineering Architecture", "Modern Data Stack", "Open Data Stack", "Declarative Data Stack", "Medallion Architecture", "Data Mesh", "Microsoft Fabric", "Inmon vs Kimball"]
  },
  {
    category: "Data Modeling",
    concepts: ["Data Modeling", "Different Levels of Data Modeling", "Entity Relationship Diagram (ERD)", "Dimensional Modeling", "Data Vault", "Anchor Modeling", "Entity-Centric Data Modeling (ECM)", "Activity Schema", "Relational Model", "Normalization", "Denormalization", "Fact Table", "Dimensions", "Slowly Changing Dimension", "Bus Matrix", "Granularity", "Cardinality"]
  },
  {
    category: "Ingestion, Movement & CDC",
    concepts: ["ETL", "ELT", "EtLT", "Reverse ETL", "ETL vs ELT", "Change Data Capture (CDC)", "Delta-Load Options", "Stream Processing", "Apache Kafka", "Backfill", "MapReduce", "Hadoop"]
  },
  {
    category: "Transformation, Orchestration & Pipelines",
    concepts: ["Data Orchestration", "DAG", "Software-Defined Asset", "Functional Data Engineering", "Declarative vs Imperative", "Apache Airflow", "Dagster", "dbt", "SQLMesh", "Notebooks", "Idempotency", "AI Orchestrators"]
  },
  {
    category: "Data Management & Governance",
    concepts: ["Data Governance", "Data Catalog", "Data Contracts", "Data Lineage", "Data Product", "Master Data Management", "Schema Evolution", "Schema Registry", "Schema Drift", "DataOps"]
  },
  {
    category: "Semantic Layer, Metrics & Federation",
    concepts: ["Semantic Layer", "Modern Semantic Layer", "Metrics Layer", "Metrics", "SQL Query Engine", "Analytics API", "Semantic SQL", "Data Federation"]
  },
  {
    category: "OLAP, BI & Analytics Evolution",
    concepts: ["Traditional OLAP Cubes", "Modern OLAP Systems", "Cube", "Business Intelligence", "BI Tools", "Pivot Table"]
  },
  {
    category: "Performance & Engine Internals",
    concepts: ["CAP Theorem", "Push-downs", "Materialized Views", "CTE", "Full Table Scan"]
  },
  {
    category: "Practice, Role & Career",
    concepts: ["Data Engineering Lifecycle", "Data Engineering Approaches", "The Role of a Data Engineer", "Data Engineer vs Software Engineer", "Retrieval-Augmented Generation (RAG)"]
  }
];

const defaultBacklinks = [
  { url: "/concepts/foundation/data-platform-architecture/", title: "The Data Engineering Toolkit" },
  { url: "/concepts/foundation/data-engineering/", title: "What is Data Engineering" },
  { url: "/concepts/foundation/data-engineer-role/", title: "Book: The History and State of Data Engineering" }
];
---

<div class="moc-container">
    <div class="moc-main-content">
        <!-- Title and Metadata -->
        <h1 class="moc-title">Data Engineering Concepts</h1>
        
        <div class="moc-meta">
            <span>Last updated Jun 8, 2026</span>
            <span class="meta-dot">·</span>
            <span>Created Aug 21, 2023</span>
            <span class="meta-dot">·</span>
            <span>5 min read</span>
        </div>
        
        <!-- Table of Contents -->
        <details class="moc-toc" open>
            <summary>Table of Contents</summary>
            <ul>
                <li><a href="#how-to-use-this-map">1 How to Use This Map</a></li>
                <li><a href="#quizzes">2 Luyện Đề Thi Thử (Practice Quizzes)</a></li>
            </ul>
        </details>
        
        <!-- Description -->
        <p class="moc-description">
            Nếu bạn muốn trở thành một kỹ sư dữ liệu (Data Engineer), hãy học các khái niệm này. Bảng phân loại dưới đây là Bản đồ nội dung (Map of Content - MOC) với 101 ý tưởng đầu vào cốt lõi kết nối tới toàn bộ Cẩm nang Kỹ thuật Dữ liệu. Đọc từ trên xuống dưới theo lộ trình học tập, hoặc nhảy vào bất kỳ chủ đề nào bạn cần đào sâu.
        </p>
        
        <!-- The Table -->
        <div class="moc-table-wrapper" id="concept-table">
            <table class="moc-table">
                <thead>
                    <tr>
                        <th class="col-category">Category</th>
                        <th class="col-concepts">Data Engineering Concepts</th>
                    </tr>
                </thead>
                <tbody>
                    {hardcodedMOC.map(group => {
                        const catSlug = group.category.toLowerCase().replace(/[^a-z0-9]+/g, '-');
                        return (
                            <tr id={`row-${catSlug}`}>
                                <td class="cat-cell">
                                    <strong>{group.category}</strong>
                                </td>
                                <td class="concepts-cell">
                                    <div class="concepts-list">
                                        {group.concepts.map((concept, index) => {
                                            const url = getConceptUrl(concept);
                                            const isLast = index === group.concepts.length - 1;
                                            return (
                                                <span class="concept-item-wrapper">
                                                    {url ? (
                                                        <a href={url} class="concept-tag active">
                                                            {concept}
                                                        </a>
                                                    ) : (
                                                        <span class="concept-tag inactive" title="Bài viết đang được cập nhật (Sắp có)">
                                                            {concept}
                                                        </span>
                                                    )}
                                                    {!isLast && <span class="comma">, </span>}
                                                </span>
                                            );
                                        })}
                                    </div>
                                </td>
                            </tr>
                        );
                    })}
                </tbody>
            </table>
        </div>
        
        <!-- How to Use Section -->
        <section class="moc-section" id="how-to-use-this-map">
            <h2>💡 How to Use This Map (Hướng dẫn sử dụng)</h2>
            <ul>
                <li><strong>Học theo lộ trình:</strong> Đọc bảng phân loại từ trên xuống dưới. Các khái niệm được sắp xếp từ cơ bản (Lưu trữ, Định dạng dữ liệu) đến nâng cao (Điều phối, Quản trị, GenAI/ML).</li>
                <li><strong>Liên kết màu đỏ:</strong> Click vào các từ khóa có nền hồng, chữ đỏ để xem chi tiết bài học chi tiết của khái niệm đó.</li>
                <li><strong>Khái niệm chưa có màu đỏ:</strong> Các khái niệm có viền xám đứt nét đang được soạn thảo và sẽ sớm xuất hiện.</li>
                <li><strong>Xem liên kết ngược (Backlinks):</strong> Ở cuối mỗi bài viết sẽ có phần Liên kết ngược giúp bạn biết khái niệm đó được tham chiếu từ những bài học nào khác, tạo thành một mạng lưới kiến thức liên kết chặt chẽ.</li>
            </ul>
        </section>

        <!-- Slot for Quizzes (which are passed from index.mdx) -->
        <slot />
    </div>
    
    <!-- Sidebar Column -->
    <aside class="moc-sidebar">
        <div class="moc-sidebar-sticky">
            <h3 class="moc-sidebar-title">Backlinks</h3>
            <div class="moc-backlinks-list">
                {defaultBacklinks.map(link => (
                    <a href={link.url} class="moc-backlink-card">
                        <span class="moc-backlink-text">{link.title}</span>
                    </a>
                ))}
            </div>
        </div>
    </aside>
</div>

<style>
/* Theme Variables */
:root {
    --moc-bg: var(--sl-color-bg);
    --moc-text: var(--sl-color-text);
    --moc-meta-text: var(--sl-color-gray-3);
    --moc-border: var(--sl-color-hairline);
    --moc-th-bg: var(--sl-color-bg-nav);
    --moc-tag-active-bg: #fff0f0;
    --moc-tag-active-text: #c92a2a;
    --moc-tag-active-border: #ffc9c9;
    --moc-tag-inactive-bg: var(--sl-color-bg-inline-code);
    --moc-tag-inactive-text: var(--sl-color-gray-4);
    --moc-tag-inactive-border: var(--sl-color-hairline);
    --moc-backlink-border: #ffc9c9;
    --moc-backlink-bg: rgba(255, 240, 240, 0.4);
    --moc-backlink-text: #c92a2a;
}

:root[data-theme="dark"] {
    --moc-tag-active-bg: #2b1414;
    --moc-tag-active-text: #ff8787;
    --moc-tag-active-border: #5c2020;
    --moc-backlink-border: #5c2020;
    --moc-backlink-bg: rgba(43, 20, 20, 0.4);
    --moc-backlink-text: #ff8787;
}

/* CSS Grid Container */
.moc-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin: 1.5rem 0;
    font-family: var(--sl-font);
}

@media (min-width: 1024px) {
    .moc-container {
        grid-template-columns: 3.2fr 1fr;
    }
}

/* Main Column Styles */
.moc-main-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

.moc-title {
    font-size: 2.5rem !important;
    font-weight: 800 !important;
    color: var(--sl-color-white);
    margin: 0 !important;
    line-height: 1.2;
}

.moc-meta {
    font-size: 0.9rem;
    color: var(--moc-meta-text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: -0.5rem;
    border-bottom: 1px solid var(--moc-border);
    padding-bottom: 1rem;
}

.meta-dot {
    opacity: 0.5;
}

/* Collapsible Table of Contents */
.moc-toc {
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--moc-border);
    border-radius: 8px;
    padding: 1rem;
    transition: all 0.3s ease;
}

.moc-toc summary {
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    color: var(--sl-color-white);
    outline: none;
    user-select: none;
}

.moc-toc ul {
    list-style: none !important;
    padding-left: 1.5rem !important;
    margin: 0.5rem 0 0 0 !important;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.moc-toc li a {
    color: var(--moc-tag-active-text);
    text-decoration: none;
    font-weight: 500;
}

.moc-toc li a:hover {
    text-decoration: underline;
}

.moc-description {
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0 !important;
    color: var(--moc-text);
}

/* MOC Table Styles */
.moc-table-wrapper {
    width: 100%;
    overflow-x: auto;
    border: 1px solid var(--moc-border);
    border-radius: 8px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
}

.moc-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    font-size: 0.95rem;
}

.moc-table th {
    background-color: var(--moc-th-bg);
    color: var(--sl-color-white);
    font-weight: 700;
    padding: 0.75rem 1rem;
    border-bottom: 2px solid var(--moc-border);
}

.col-category {
    width: 25%;
    min-width: 180px;
}

.col-concepts {
    width: 75%;
}

.moc-table td {
    padding: 1rem;
    border-bottom: 1px solid var(--moc-border);
    vertical-align: top;
}

.cat-cell {
    color: var(--sl-color-white);
    font-weight: 700;
}

.concepts-cell {
    line-height: 2.1;
}

.concepts-list {
    word-break: break-word;
}

.concept-item-wrapper {
    display: inline;
}

/* Concept Tags */
.concept-tag {
    display: inline-block;
    padding: 0.1rem 0.4rem;
    font-size: 0.88rem;
    font-weight: 500;
    border-radius: 4px;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    margin: 0.15rem 0;
    text-decoration: none !important;
}

.concept-tag.active {
    background-color: var(--moc-tag-active-bg);
    color: var(--moc-tag-active-text);
    border: 1px solid var(--moc-tag-active-border);
}

.concept-tag.active:hover {
    background-color: var(--moc-tag-active-text);
    color: var(--sl-color-bg);
    border-color: var(--moc-tag-active-text);
    transform: translateY(-1px);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
}

.concept-tag.inactive {
    background-color: var(--moc-tag-inactive-bg);
    color: var(--moc-tag-inactive-text);
    border: 1px dashed var(--moc-tag-inactive-border);
    cursor: not-allowed;
}

.comma {
    color: var(--moc-text);
    margin-right: 0.25rem;
    opacity: 0.5;
}

/* Sidebar Column Styles */
.moc-sidebar {
    display: block;
}

.moc-sidebar-sticky {
    position: sticky;
    top: 6rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.moc-sidebar-title {
    font-size: 1.1rem !important;
    font-weight: 700 !important;
    font-family: monospace;
    color: var(--sl-color-white);
    margin: 0 !important;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--moc-border);
    padding-bottom: 0.5rem;
}

.moc-backlinks-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
}

.moc-backlink-card {
    display: block;
    border: 1px solid var(--moc-backlink-border);
    background-color: var(--moc-backlink-bg);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    text-decoration: none !important;
    transition: all 0.2s ease;
    text-align: center;
}

.moc-backlink-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
    background-color: var(--moc-tag-active-text);
}

.moc-backlink-card:hover .moc-backlink-text {
    color: var(--sl-color-bg);
}

.moc-backlink-text {
    color: var(--moc-backlink-text);
    font-weight: 600;
    font-size: 0.9rem;
    transition: color 0.2s ease;
}

/* Section Styles */
.moc-section {
    margin-top: 2rem;
    border-top: 1px solid var(--moc-border);
    padding-top: 1.5rem;
}

.moc-section h2 {
    font-size: 1.5rem !important;
    color: var(--sl-color-white);
    margin-bottom: 1rem !important;
    font-weight: 600;
}

.moc-section ul {
    list-style: disc !important;
    padding-left: 1.5rem !important;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.moc-section li {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--moc-text);
}
</style>
