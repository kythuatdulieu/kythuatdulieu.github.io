---
import { getCollection } from 'astro:content';

// Dynamically fetch all concepts from the content folder
const allDocs = await getCollection('docs');
const concepts = allDocs.filter(doc => doc.id.startsWith('concepts/'));

// Group concepts by category
const groupedConcepts = {};

concepts.forEach(concept => {
    const category = concept.data.category || 'Uncategorized';
    if (!groupedConcepts[category]) {
        groupedConcepts[category] = [];
    }
    
    // Create a clean English title from the slug if not provided, for the tag cloud
    // E.g., 'apache-kafka' -> 'Apache Kafka'
    const rawSlug = concept.id.replace('concepts/', '').replace('.md', '').replace('.mdx', '');
    let shortTitle = rawSlug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
    
    // Some acronyms should be fully uppercase ideally, but Title Case is safe enough
    // We can also extract English terms if they are inside the main title (e.g., "- OLAP")
    const titleMatch = concept.data.title.match(/-\s*([A-Za-z0-9\s]+)$/);
    if (titleMatch && titleMatch[1]) {
        shortTitle = titleMatch[1].trim();
    }
    
    groupedConcepts[category].push({
        url: `/${concept.slug}/`,
        title: shortTitle,
        dataConcept: rawSlug
    });
});

// Define a preferred order for known categories (to match the logical learning path)
const categoryOrder = [
    "Foundation",
    "Database & Storage",
    "Data Warehouse",
    "Data Lake & Lakehouse",
    "ETL / ELT",
    "Batch Processing",
    "Streaming Processing",
    "Orchestration",
    "Data Quality & Governance",
    "Data Architecture & Paradigms",
    "Modern Data Stack",
    "System Design & Cloud",
    "Vector Database & Search",
    "Large Language Models (LLMs)",
    "LLMOps & Real-world AI"
];

// Sort categories based on predefined order, unknown categories go to the end
const sortedCategories = Object.keys(groupedConcepts).sort((a, b) => {
    let indexA = categoryOrder.findIndex(cat => a.toLowerCase().includes(cat.toLowerCase()));
    let indexB = categoryOrder.findIndex(cat => b.toLowerCase().includes(cat.toLowerCase()));
    if (indexA === -1) indexA = 999;
    if (indexB === -1) indexB = 999;
    return indexA - indexB;
});
---

<table class="moc-table">
    <tbody id="moc-table-body">
        {sortedCategories.map(category => (
            <tr class="moc-row" data-category={category}>
                <th class="moc-category-cell">
                    <span class="drag-handle" title="Kéo thả để sắp xếp">⠿</span>
                    {category}
                </th>
                <td class="moc-links-cell">
                    {groupedConcepts[category].sort((a, b) => a.title.localeCompare(b.title)).map((concept, index) => (
                        <span>
                            <a href={concept.url} class="concept-link" data-concept={concept.dataConcept}>{concept.title}</a>{index < groupedConcepts[category].length - 1 ? ', ' : ''}
                        </span>
                    ))}
                </td>
            </tr>
        ))}
    </tbody>
</table>

<style>
.moc-table {
    width: 100%;
    max-width: 850px;
    margin: 2rem auto;
    border-collapse: collapse;
    font-family: var(--sl-font);
    font-size: 0.95rem;
}
.moc-row {
    border-bottom: 1px solid var(--sl-color-hairline);
    transition: background-color 0.2s;
    background-color: transparent;
}
.moc-row:hover {
    background-color: var(--sl-color-bg-nav);
}
.moc-category-cell {
    width: 30%;
    padding: 1.2rem 1rem 1.2rem 0;
    text-align: left;
    vertical-align: top;
    font-weight: 600;
    color: var(--sl-color-white);
    display: flex;
    align-items: flex-start;
}
.moc-links-cell {
    width: 70%;
    padding: 1.2rem 0 1.2rem 1rem;
    vertical-align: top;
    line-height: 1.8;
    color: var(--sl-color-gray-3);
}
.drag-handle {
    cursor: grab;
    color: var(--sl-color-gray-4);
    margin-right: 0.5rem;
    font-size: 1.1rem;
    user-select: none;
    opacity: 0.3;
    transition: opacity 0.2s;
    padding-top: 0.1rem;
}
.moc-row:hover .drag-handle {
    opacity: 1;
}
.concept-link {
    color: var(--sl-color-accent-high);
    text-decoration: none;
    transition: color 0.2s;
}
.concept-link:hover {
    color: var(--sl-color-accent);
    text-decoration: underline;
}
.sortable-ghost {
    opacity: 0.4;
    background-color: var(--sl-color-gray-5) !important;
}
</style>

<script>
import Sortable from 'https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/+esm';

function initSortable() {
    const tbody = document.getElementById('moc-table-body');
    if (!tbody) return;

    // Load saved row order
    const savedCategoryOrder = JSON.parse(localStorage.getItem('moc-table-order') || 'null');
    if (savedCategoryOrder) {
        const rows = Array.from(tbody.querySelectorAll('.moc-row'));
        savedCategoryOrder.forEach(categoryName => {
            const el = rows.find(r => r.dataset.category === categoryName);
            if (el) tbody.appendChild(el);
        });
    }

    // Initialize Sortable on tbody
    new Sortable(tbody, {
        handle: '.drag-handle',
        animation: 150,
        ghostClass: 'sortable-ghost',
        onEnd: function () {
            const order = Array.from(tbody.querySelectorAll('.moc-row')).map(el => el.dataset.category);
            localStorage.setItem('moc-table-order', JSON.stringify(order));
        }
    });
}

document.addEventListener('DOMContentLoaded', initSortable);
document.addEventListener('astro:page-load', initSortable);
</script>
