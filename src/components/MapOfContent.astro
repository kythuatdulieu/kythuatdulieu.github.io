---
import { getCollection } from 'astro:content';

// Dynamically fetch all concepts from the content folder
const allDocs = await getCollection('docs');
const concepts = allDocs.filter(doc => doc.id.startsWith('concepts/'));

// Group concepts by category
const groupedConcepts = {};

concepts.forEach(concept => {
    const category = concept.data.category || 'Uncategorized';
    if (!groupedConcepts[category]) {
        groupedConcepts[category] = [];
    }
    
    // Create a clean English title from the slug if not provided, for the tag cloud
    // E.g., 'apache-kafka' -> 'Apache Kafka'
    const rawSlug = concept.id.replace('concepts/', '').replace('.md', '').replace('.mdx', '');
    let shortTitle = rawSlug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
    
    // Some acronyms should be fully uppercase ideally, but Title Case is safe enough
    // We can also extract English terms if they are inside the main title (e.g., "- OLAP")
    const titleMatch = concept.data.title.match(/-\s*([A-Za-z0-9\s]+)$/);
    if (titleMatch && titleMatch[1]) {
        shortTitle = titleMatch[1].trim();
    }
    
    groupedConcepts[category].push({
        url: `/${concept.slug}/`,
        title: shortTitle,
        dataConcept: rawSlug
    });
});

// Define a preferred order for known categories (to match the logical learning path)
const categoryOrder = [
    "Foundation",
    "Database & Storage",
    "Data Warehouse",
    "Data Lake & Lakehouse",
    "ETL / ELT",
    "Batch Processing",
    "Streaming Processing",
    "Orchestration",
    "Data Quality & Governance",
    "Data Architecture & Paradigms",
    "Modern Data Stack",
    "System Design & Cloud",
    "Vector Database & Search",
    "Large Language Models (LLMs)",
    "LLMOps & Real-world AI"
];

// Sort categories based on predefined order, unknown categories go to the end
const sortedCategories = Object.keys(groupedConcepts).sort((a, b) => {
    let indexA = categoryOrder.findIndex(cat => a.toLowerCase().includes(cat.toLowerCase()));
    let indexB = categoryOrder.findIndex(cat => b.toLowerCase().includes(cat.toLowerCase()));
    if (indexA === -1) indexA = 999;
    if (indexB === -1) indexB = 999;
    return indexA - indexB;
});
---

<div class="moc-container" id="moc-container">
    {sortedCategories.map(category => (
        <div class="moc-group" data-category={category}>
            <h3 class="moc-category">
                <span class="drag-handle">⠿</span>
                {category}
            </h3>
            <div class="moc-grid" data-category={category}>
                {groupedConcepts[category].sort((a, b) => a.title.localeCompare(b.title)).map(concept => (
                    <a href={concept.url} class="concept-tag" data-concept={concept.dataConcept}>
                        {concept.title}
                    </a>
                ))}
            </div>
        </div>
    ))}
</div>

<style>
.moc-container {
    max-width: 850px;
    margin: 0 auto;
    font-family: var(--sl-font);
}
.moc-group {
    background: transparent;
    transition: transform 0.2s ease;
}
.moc-category {
    margin-top: 2rem !important;
    margin-bottom: 1.2rem !important;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--sl-color-white);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--sl-color-hairline);
    display: flex;
    align-items: center;
}
.drag-handle {
    cursor: grab;
    color: var(--sl-color-gray-4);
    margin-right: 0.75rem;
    font-size: 1.2rem;
    user-select: none;
    opacity: 0.5;
    transition: opacity 0.2s;
}
.moc-category:hover .drag-handle {
    opacity: 1;
}
.moc-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1rem;
    min-height: 40px; /* To allow dropping when empty */
}
.concept-tag {
    display: inline-block;
    padding: 0.4rem 0.85rem;
    background-color: var(--sl-color-bg-nav);
    color: var(--sl-color-text-accent);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 9999px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none !important;
    transition: all 0.2s ease-in-out;
    cursor: grab;
}
.concept-tag:hover {
    background-color: var(--sl-color-accent);
    color: var(--sl-color-text-invert);
    border-color: var(--sl-color-accent);
    transform: translateY(-1px);
    box-shadow: var(--shadow-sm);
}
.sortable-ghost {
    opacity: 0.4;
    background-color: var(--sl-color-gray-5);
}
</style>

<script>
import Sortable from 'https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/+esm';

function initSortable() {
    const container = document.getElementById('moc-container');
    if (!container) return;

    // Load saved category order
    const savedCategoryOrder = JSON.parse(localStorage.getItem('moc-category-order') || 'null');
    if (savedCategoryOrder) {
        const groups = Array.from(container.querySelectorAll('.moc-group'));
        savedCategoryOrder.forEach(categoryName => {
            const el = groups.find(g => g.dataset.category === categoryName);
            if (el) container.appendChild(el);
        });
    }

    // Load saved tag placements
    const savedTagPlacement = JSON.parse(localStorage.getItem('moc-tag-placement') || 'null');
    if (savedTagPlacement) {
        Object.keys(savedTagPlacement).forEach(category => {
            const grid = container.querySelector(`.moc-grid[data-category="${category}"]`);
            if (grid) {
                const tagSlugs = savedTagPlacement[category];
                tagSlugs.forEach(slug => {
                    const tag = document.querySelector(`.concept-tag[data-concept="${slug}"]`);
                    if (tag) grid.appendChild(tag);
                });
            }
        });
    }

    // Initialize Category Sortable
    new Sortable(container, {
        handle: '.drag-handle',
        animation: 150,
        ghostClass: 'sortable-ghost',
        onEnd: function () {
            const order = Array.from(container.querySelectorAll('.moc-group')).map(el => el.dataset.category);
            localStorage.setItem('moc-category-order', JSON.stringify(order));
        }
    });

    // Initialize Tag Sortable across grids
    const grids = container.querySelectorAll('.moc-grid');
    grids.forEach(grid => {
        new Sortable(grid, {
            group: 'shared',
            animation: 150,
            ghostClass: 'sortable-ghost',
            onEnd: function () {
                const state = {};
                grids.forEach(g => {
                    const cat = g.dataset.category;
                    const tags = Array.from(g.querySelectorAll('.concept-tag')).map(t => t.dataset.concept);
                    state[cat] = tags;
                });
                localStorage.setItem('moc-tag-placement', JSON.stringify(state));
            }
        });
    });
}

document.addEventListener('DOMContentLoaded', initSortable);
document.addEventListener('astro:page-load', initSortable);
</script>
