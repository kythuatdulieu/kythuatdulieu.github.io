---
import { getCollection } from 'astro:content';
import { conceptCategories } from '../config/categories.js';

const allDocs = await getCollection('docs');
const existingConcepts = allDocs.filter(doc => doc.id.startsWith('concepts/'));

const domains = [
  {
    id: "domain-1",
    label: "1. Cơ sở & Kiến trúc",
    description: "Nền móng về kỹ thuật dữ liệu, vòng đời dữ liệu, thiết kế hệ thống và các mô hình kiến trúc phân tích (Medallion, Lambda, Kappa, Data Mesh).",
    prefix: "1-",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1"></rect><rect x="14" y="3" width="7" height="5" rx="1"></rect><rect x="14" y="12" width="7" height="9" rx="1"></rect><rect x="3" y="16" width="7" height="5" rx="1"></rect></svg>`
  },
  {
    id: "domain-2",
    label: "2. Lưu trữ & Quản lý dữ liệu",
    description: "Thiết kế cơ sở dữ liệu (OLTP, OLAP, HTAP), định dạng file mở (Parquet, Delta, Iceberg), hồ dữ liệu (Lakehouse) và Cloud platforms.",
    prefix: "2-",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5V19A9 3 0 0 0 21 19V5"></path><path d="M3 12A9 3 0 0 0 21 12"></path></svg>`
  },
  {
    id: "domain-3",
    label: "3. Tích hợp & Biến đổi dữ liệu",
    description: "Quy trình tích hợp (ETL/ELT, CDC, Idempotency), dbt transformations, orchestration (Airflow, Dagster) và xử lý theo lô lớn (Batch Processing).",
    prefix: "3-",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>`
  },
  {
    id: "domain-4",
    label: "4. Xử lý thời gian thực",
    description: "Xử lý luồng dữ liệu liên tục (Streaming Processing), kiến trúc Spark Streaming vs Flink, quản lý State, Event-Time và Watermarking.",
    prefix: "4-",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>`
  },
  {
    id: "domain-5",
    label: "5. Chất lượng & Quản trị",
    description: "Đảm bảo độ tin cậy dữ liệu (Data Quality, SLA/SLO, Observability), thiết lập Data Catalog, bảo mật và quản trị siêu dữ liệu tập trung.",
    prefix: "5-",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`
  },
  {
    id: "domain-6",
    label: "6. AI & Machine Learning",
    description: "Hạ tầng dữ liệu cho AI/ML: thiết kế Feature Store, kỹ thuật Chunking dữ liệu, Embedding Models, Vector Database và tối ưu ứng dụng RAG.",
    prefix: "6-",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>`
  }
];

const domainsData = domains.map(domain => {
    const categoriesInDomain = conceptCategories
        .filter(cat => cat.slug.startsWith(domain.prefix))
        .map(cat => {
            const docsInCat = existingConcepts.filter(doc => doc.id.startsWith(`concepts/${cat.slug}/`));
            return {
                categorySlug: cat.slug,
                categoryLabel: cat.label,
                concepts: docsInCat.map(doc => {
                    let title = doc.data.title;
                    const match = title.match(/-\s*([a-zA-Z0-9\s]+)$/);
                    if (match && match[1]) title = match[1].trim();
                    
                    return {
                        title: title,
                        url: `/${doc.slug}/`
                    };
                })
            };
        })
        .filter(cat => cat.concepts.length > 0);

    return {
        ...domain,
        categories: categoriesInDomain
    };
}).filter(d => d.categories.length > 0);
---

<div class="moc-container">
    <div class="domains-grid">
        {domainsData.map(domain => (
            <div class="domain-card" id={domain.id}>
                <div class="domain-header">
                    <div class="domain-icon" set:html={domain.svg} />
                    <h3 class="domain-title">{domain.label.split('. ')[1] || domain.label}</h3>
                </div>
                <p class="domain-desc">{domain.description}</p>
                <div class="domain-categories">
                    {domain.categories.map(cat => (
                        <a href={cat.concepts[0].url} class="cat-tag">
                            {cat.categoryLabel}
                        </a>
                    ))}
                </div>
            </div>
        ))}
    </div>
</div>

<style>
.moc-container {
    width: 100%;
    margin: 0;
    font-family: var(--sl-font-system), sans-serif;
}

.domains-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
}

@media (min-width: 768px) {
    .domains-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (min-width: 1200px) {
    .domains-grid {
        grid-template-columns: repeat(3, 1fr);
    }
}

/* Premium Card Design */
.domain-card {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    background: var(--sl-color-bg-nav, rgba(20, 20, 25, 0.5));
    border: 1px solid var(--sl-color-hairline, rgba(255, 255, 255, 0.08));
    border-radius: 16px;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    position: relative;
    overflow: hidden;
}

.domain-card:hover {
    border-color: var(--sl-color-gray-4);
    transform: translateY(-2px);
    box-shadow: 0 10px 40px -10px rgba(0,0,0,0.5);
}

.domain-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
}

.domain-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    color: var(--sl-color-text-accent, var(--sl-color-accent));
    background: rgba(var(--sl-color-accent-rgb, 100, 100, 255), 0.1);
    border-radius: 8px;
    flex-shrink: 0;
}

.domain-title {
    margin: 0 !important;
    font-size: 1.25rem !important;
    font-weight: 600 !important;
    color: var(--sl-color-white) !important;
    line-height: 1.2 !important;
    letter-spacing: -0.02em;
}

.domain-desc {
    font-size: 0.9rem;
    color: var(--sl-color-gray-3);
    line-height: 1.6;
    margin: 0 0 1.5rem 0 !important;
    flex-grow: 1;
}

/* Category Tags */
.domain-categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
}

.cat-tag {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--sl-color-gray-2) !important;
    background: var(--sl-color-black, rgba(0, 0, 0, 0.3));
    border: 1px solid var(--sl-color-hairline, rgba(255, 255, 255, 0.05));
    padding: 0.35rem 0.75rem;
    border-radius: 9999px;
    text-decoration: none !important;
    transition: all 0.2s ease;
}

    opacity: 1;
    transform: translateX(0);
    color: var(--sl-color-accent-high);
}
</style>
