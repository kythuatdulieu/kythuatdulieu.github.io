---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Head.astro';

// Get page metadata
const { entry, id } = Astro.props;
const isDoc = !!entry;

// Generate JSON-LD for Articles if it's a content page
let schema = null;

if (isDoc && entry.data) {
  schema = {
    "@context": "https://schema.org",
    "@type": "TechArticle",
    "headline": entry.data.title,
    "description": entry.data.description || `Bài viết về ${entry.data.title}`,
    "author": {
      "@type": "Person",
      "name": "Kỹ thuật Dữ liệu",
      "url": "https://kythuatdulieu.github.io"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Data Engineering Handbook",
      "url": "https://kythuatdulieu.github.io"
    },
    "inLanguage": "vi-VN"
  };
}
---

<Default {...Astro.props} />

{schema && (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
)}

<script is:inline>
  // Pre-paint: áp lựa chọn đọc từ localStorage trước khi render để không nháy màn hình.
  (function () {
    try {
      var d = document.documentElement;
      var theme = localStorage.getItem('dehb-theme') || localStorage.getItem('starlight-theme');
      if (theme === 'auto' || !theme) {
        theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      d.setAttribute('data-theme', theme);
      d.setAttribute('data-measure', localStorage.getItem('dehb-measure') || 'medium');
      d.setAttribute('data-font', localStorage.getItem('dehb-font') || 'sans');
      var scale = localStorage.getItem('dehb-font-scale');
      if (scale) d.style.setProperty('--reading-font-scale', scale);
    } catch (e) {}
  })();
</script>

