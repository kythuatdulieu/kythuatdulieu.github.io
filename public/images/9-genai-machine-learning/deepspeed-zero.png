	<script>
		// Track active YT.Player instances for consent revocation teardown.
		window._ytPlayers = window._ytPlayers || [];

		function youtubeTracking() {
			if ( window._ytTrackingInitialized ) return;
			window._ytTrackingInitialized = true;

			// Activate consent-gated oEmbed iframes: data-src → src.
			document.querySelectorAll( '.yt-consent-placeholder iframe[data-src]' ).forEach( function( iframe ) {
				iframe.src = iframe.getAttribute( 'data-src' );
				iframe.removeAttribute( 'aria-hidden' );
				iframe.removeAttribute( 'tabindex' );
			} );

			// Remove play button overlays and load YouTube poster (now consent is granted).
			document.querySelectorAll( '.yt-consent-placeholder__overlay' ).forEach( function( el ) {
				el.remove();
			} );
			document.querySelectorAll( '.yt-consent-placeholder' ).forEach( function( el ) {
				el.removeAttribute( 'role' );
				el.removeAttribute( 'aria-label' );
				var poster = el.getAttribute( 'data-poster' );
				if ( poster ) {
					el.style.backgroundImage = 'url(' + poster + ')';
				}
			} );

			// Load YouTube iframe API.
			if ( ! document.getElementById( 'iframe-analytics' ) ) {
				var tag = document.createElement('script');
				tag.id = 'iframe-analytics';
				tag.src = 'https://www.youtube.com/iframe_api';
				var firstScriptTag = document.getElementsByTagName('script')[0];
				firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);
			}

			var tries = 0;
			( function initPlayers() {
				if ( typeof YT === 'undefined' || typeof YT.Player === 'undefined' ) {
					if ( tries++ < 40 ) return setTimeout( initPlayers, 500 );
					return;
				}

				var videoData = ( typeof analytics !== 'undefined' && analytics.config )
					? analytics.config.webAnalyticsConfiguration.coreData
					: {};
				var isLoggedIn = document.body.classList.contains( 'logged-in' );
				var pageName = ( videoData.pageName || document.title );

				function onStateChange( event ) {
					var data = {};
					var player = event.target;
					var videoInfo = ( typeof player.getVideoData === 'function' ) ? player.getVideoData() : {};
					var vidTitle = videoInfo.title || pageName;
					var vidId = videoInfo.video_id || '';

					switch ( event.data ) {
						case 0:
							data = { behavior: 245, actionType: 'CL', contentTags: { vidnm: vidTitle, vidid: vidId } };
							break;
						case 1:
							data = { behavior: 240, actionType: 'CL', contentTags: { vidnm: vidTitle, vidid: vidId } };
							break;
						case 2:
							data = { behavior: 241, actionType: 'CL', contentTags: { vidnm: vidTitle, vidid: vidId } };
							break;
						default:
							return;
					}
					if ( typeof analytics !== 'undefined' && analytics.capturePageAction ) {
						analytics.capturePageAction( player.getIframe(), data );
					}
					if ( isLoggedIn ) {
						console.log( data );
					}
				}

				function setupPlayer( el, i ) {
					if ( ! el.id ) el.id = 'yt-player-' + i;
					var p = new YT.Player( el.id, {
						events: {
							onReady: function() {
								var info = ( typeof p.getVideoData === 'function' ) ? p.getVideoData() : {};
								var iframe = p.getIframe();
								if ( info.title && iframe ) {
									iframe.setAttribute( 'data-bi-cN', info.title );
									iframe.setAttribute( 'data-bi-id', info.video_id || '' );
								}
							},
							onStateChange: onStateChange
						}
					} );
					window._ytPlayers.push( p );
				}

				// Single video page — #video-analytics div → YT.Player.
				// Uses coreData.pageName for vidnm to stay consistent with
				// legacy awa.js reporting (other embeds use YT video title).
				var singleEl = document.getElementById( 'video-analytics' );
				if ( singleEl ) {
					var fallbackUrl = singleEl.getAttribute( 'data-fallback-url' );

					var singlePlayer = new YT.Player( 'video-analytics', {
						width:   singleEl.getAttribute( 'data-width' ),
						height:  singleEl.getAttribute( 'data-height' ),
						videoId: singleEl.getAttribute( 'data-youtube-video-id' ),
						host:    'https://www.youtube-nocookie.com',
						events:  {
							onReady: function() {
								var info = ( typeof singlePlayer.getVideoData === 'function' ) ? singlePlayer.getVideoData() : {};
								var el = singlePlayer.getIframe();
								if ( el ) {
									if ( info.title ) {
										el.setAttribute( 'data-bi-cN', info.title );
										el.setAttribute( 'data-bi-id', info.video_id || '' );
									}
									if ( fallbackUrl ) {
										el.setAttribute( 'data-fallback-url', fallbackUrl );
									}
								}
							},
							onStateChange: function( event ) {
								var data = {};
								var vidId = singleEl.getAttribute( 'data-youtube-video-id' ) || '';

								switch ( event.data ) {
									case 0:
										data = { behavior: 245, actionType: 'CL', contentTags: { vidnm: pageName, vidid: vidId } };
										break;
									case 1:
										data = { behavior: 240, actionType: 'CL', contentTags: { vidnm: pageName, vidid: vidId } };
										break;
									case 2:
										data = { behavior: 241, actionType: 'CL', contentTags: { vidnm: pageName, vidid: vidId } };
										break;
									default:
										return;
								}
								if ( typeof analytics !== 'undefined' && analytics.capturePageAction ) {
									analytics.capturePageAction( singlePlayer.getIframe(), data );
								}
								if ( isLoggedIn ) {
									console.log( data );
								}
							}
						}
					} );
					window._ytPlayers.push( singlePlayer );
				}

				// All other YouTube iframes (oEmbed, block embeds).
				var iframes = document.querySelectorAll( 'iframe[src*="youtube-nocookie.com"], iframe[src*="youtube.com/embed"]' );
				iframes.forEach( function( iframe, i ) {
					if ( iframe.id === 'video-analytics' ) return;
					setupPlayer( iframe, i );
				} );
			} )();
		}

		// Teardown: destroy players and restore consent placeholders.
		function youtubeRevoke() {
			window._ytTrackingInitialized = false;

			window._ytPlayers.forEach( function( p ) {
				try { p.destroy(); } catch( e ) {}
			} );
			window._ytPlayers = [];

			document.querySelectorAll( '.yt-consent-placeholder iframe' ).forEach( function( iframe ) {
				iframe.removeAttribute( 'src' );
				iframe.setAttribute( 'aria-hidden', 'true' );
				iframe.setAttribute( 'tabindex', '-1' );
			} );

			var consentMsg = "Video playback requires cookie consent";

			document.querySelectorAll( '.yt-consent-placeholder' ).forEach( function( el ) {
				el.style.backgroundImage = 'none';
				el.setAttribute( 'role', 'region' );
				el.setAttribute( 'aria-label', consentMsg );

				if ( ! el.querySelector( '.yt-consent-placeholder__play' ) ) {
					var overlay = document.createElement( 'div' );
					overlay.className = 'yt-consent-placeholder__overlay';
					var btn = document.createElement( 'button' );
					btn.className = 'yt-consent-placeholder__play';
					btn.innerHTML = '<svg width="42" height="42" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><g fill="none" fill-rule="evenodd"><circle fill="#000" opacity=".556" cx="21" cy="21" r="21"/><path stroke="#FFF" d="M27.5 22l-12 8.5v-17z"/></g></svg><span class="yt-consent-placeholder__label">' + consentMsg + '</span>';
					btn.addEventListener( 'click', function() {
						if ( typeof window.siteConsent !== 'undefined' && siteConsent.manageConsent ) {
							siteConsent.manageConsent();
						}
					} );
					overlay.appendChild( btn );
					el.appendChild( overlay );
				}
			} );
		}

		// Handle play button clicks before consent — clicking triggers consent prompt.
		document.querySelectorAll( '.yt-consent-placeholder__play' ).forEach( function( btn ) {
			btn.addEventListener( 'click', function() {
				if ( typeof window.siteConsent !== 'undefined' && siteConsent.manageConsent ) {
					siteConsent.manageConsent();
				} else {
					youtubeTracking();
				}
			} );
		} );

		if ( typeof window.siteConsent !== 'undefined' ) {
			var userConsent = window.siteConsent.getConsent();
			if ( userConsent.Analytics && userConsent.Advertising && userConsent.SocialMedia ) {
				youtubeTracking();
			}
		} else {
			// No consent manager (local dev) — activate after short delay.
			setTimeout( function() {
				if ( typeof window.siteConsent === 'undefined' ) {
					youtubeTracking();
				}
			}, 2000 );
		}

		// Listen for consent revocation — tear down players if consent is withdrawn.
		if ( typeof WcpConsent !== 'undefined' ) {
			WcpConsent.onConsentChanged( function() {
				if ( ! WcpConsent.siteConsent ) return;
				var c = WcpConsent.siteConsent.getConsent();
				if ( ! c.Analytics || ! c.Advertising || ! c.SocialMedia ) {
					youtubeRevoke();
				}
			} );
		}
	</script>
